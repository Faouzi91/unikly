{
  "title": "Unikly — Business Metrics",
  "uid": "unikly-business-metrics",
  "schemaVersion": 38,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Jobs Created (total)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(unikly_job_created_total)",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 2,
      "title": "Jobs Created Over Time (per hour)",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(unikly_job_created_total[1h])) * 3600",
          "legendFormat": "Jobs/hour"
        }
      ]
    },
    {
      "id": 3,
      "title": "Proposals Submitted (total)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 4, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(unikly_proposal_submitted_total)",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 4,
      "title": "Payments Completed (total)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(unikly_payment_completed_total)",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 5,
      "title": "Payments Completed Over Time (per hour)",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 8, "w": 18, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(unikly_payment_completed_total[1h])) * 3600",
          "legendFormat": "Payments/hour"
        }
      ]
    },
    {
      "id": 6,
      "title": "Matches Generated (total)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 12, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(unikly_match_generated_total)",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 7,
      "title": "Matching Queue Size",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 12, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "unikly_matching_queue_size",
          "legendFormat": "Queue"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Payment Failures (total)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 12, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(unikly_payment_failed_total)",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    }
  ]
}
