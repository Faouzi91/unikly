{
  "realm": "unikly",
  "enabled": true,
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 300,
  "ssoSessionMaxLifespan": 2592000,
  "refreshTokenMaxReuse": 0,
  "sslRequired": "none",
  "roles": {
    "realm": [
      {
        "name": "ROLE_CLIENT",
        "description": "Client who posts jobs and hires freelancers"
      },
      {
        "name": "ROLE_FREELANCER",
        "description": "Freelancer who applies to jobs"
      },
      {
        "name": "ROLE_ADMIN",
        "description": "Platform administrator"
      }
    ]
  },
  "clients": [
    {
      "clientId": "unikly-frontend",
      "name": "Unikly Frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:4200/*",
        "http://localhost/*",
        "http://localhost:80/*"
      ],
      "webOrigins": [
        "http://localhost:4200",
        "http://localhost",
        "http://localhost:80"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocol": "openid-connect",
      "fullScopeAllowed": true
    },
    {
      "clientId": "unikly-backend",
      "name": "Unikly Backend",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "secret": "unikly-backend-secret",
      "redirectUris": [],
      "webOrigins": [],
      "protocol": "openid-connect",
      "fullScopeAllowed": true
    }
  ],
  "scopeMappings": [
    {
      "client": "unikly-frontend",
      "roles": [
        "ROLE_CLIENT",
        "ROLE_FREELANCER",
        "ROLE_ADMIN"
      ]
    }
  ],
  "users": [
    {
      "username": "testclient@unikly.com",
      "email": "testclient@unikly.com",
      "firstName": "Test",
      "lastName": "Client",
      "enabled": true,
      "emailVerified": true,
      "realmRoles": ["ROLE_CLIENT"],
      "credentials": [
        {
          "type": "password",
          "value": "Test1234!",
          "temporary": false
        }
      ]
    },
    {
      "username": "testfreelancer@unikly.com",
      "email": "testfreelancer@unikly.com",
      "firstName": "Test",
      "lastName": "Freelancer",
      "enabled": true,
      "emailVerified": true,
      "realmRoles": ["ROLE_FREELANCER"],
      "credentials": [
        {
          "type": "password",
          "value": "Test1234!",
          "temporary": false
        }
      ]
    },
    {
      "username": "admin@unikly.com",
      "email": "admin@unikly.com",
      "firstName": "Platform",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "realmRoles": ["ROLE_ADMIN"],
      "credentials": [
        {
          "type": "password",
          "value": "Admin1234!",
          "temporary": false
        }
      ]
    }
  ]
}
